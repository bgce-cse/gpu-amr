{
    "version": 3,
    "configurePresets": [
        {
            "name": "gcc-base",
            "generator": "Unix Makefiles",
            "toolchainFile": "cmake/toolchain/gcc.cmake"
        },
        {
            "name": "clang-base",
            "generator": "Unix Makefiles",
            "toolchainFile": "cmake/toolchain/clang.cmake"
        },
        {
            "name": "gcc-asan",
            "inherits": "gcc-base",
            "binaryDir": "build/gcc-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "LOG_LEVEL": "TRACE",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "gcc-debug",
            "inherits": "gcc-base",
            "binaryDir": "build/gcc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "LOG_LEVEL": "DEBUG",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "gcc-relwdebinfo",
            "inherits": "gcc-base",
            "binaryDir": "build/gcc-relwdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "LOG_LEVEL": "INFO",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "gcc-release",
            "inherits": "gcc-base",
            "binaryDir": "build/gcc-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "LOG_LEVEL": "PROGRESS",
                "CONTRACTS": "OFF",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF",
                "ENABLE_SPDLOG": "OFF"
            }
        },
        {
            "name": "gcc-cuda-release",
            "inherits": "gcc-base",
            "binaryDir": "build/gcc-cuda-stable",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "LOG_LEVEL": "INFO",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF",
                "ENABLE_CUDA_AMR": "ON",
                "ENABLE_SPDLOG": "OFF",
                "BUILD_TESTING": "OFF",
                "BUILD_BENCHMARKS": "OFF",
                "CMAKE_CUDA_COMPILER": "/usr/bin/nvcc",
                "CUDAToolkit_ROOT": "/usr/local/cuda-12"
            }
        },
        {
            "name": "clang-debug",
            "inherits": "clang-base",
            "binaryDir": "build/clang-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "LOG_LEVEL": "DEBUG",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "clang-release",
            "inherits": "clang-base",
            "binaryDir": "build/clang-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "LOG_LEVEL": "INFO",
                "CONTRACTS": "ON",
                "EXECUTION": "SEQ",
                "ENABLE_SANITIZERS": "OFF"
            }
        }
    ],

    "buildPresets": [
        {
            "name": "build-base",
            "hidden": true,
            "jobs": 16,
            "verbose": true
        },
        {
            "name": "gcc-asan",
            "inherits": "build-base",
            "configurePreset": "gcc-asan"
        },
        {
            "name": "gcc-debug",
            "inherits": "build-base",
            "configurePreset": "gcc-debug"
        },
        {
            "name": "gcc-relwdebinfo",
            "inherits": "build-base",
            "configurePreset": "gcc-relwdebinfo"
        },
        {
            "name": "gcc-release",
            "inherits": "build-base",
            "configurePreset": "gcc-release"
        },
        {
            "name": "gcc-cuda-release",
            "inherits": "build-base",
            "configurePreset": "gcc-cuda-release"
        },
        {
            "name": "clang-debug",
            "inherits": "build-base",
            "configurePreset": "clang-debug"
        },
        {
            "name": "clang-release",
            "inherits": "build-base",
            "configurePreset": "clang-release"
        }
    ]
}
